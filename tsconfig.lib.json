{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/index.ts", "src/**/*.ts", "src/**/*.vue"],
  "exclude": ["src/App.vue", "src/main.ts", "src/dev.css", "node_modules"]
}
