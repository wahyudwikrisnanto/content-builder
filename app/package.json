{
  "name": "tmdr-content-builder",
  "private": false,
  "version": "1.0.2",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc -p tsconfig.lib.json",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "prepare": "vite build && vue-tsc -p tsconfig.lib.json"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vue": "^3.5.34",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.3.4"
  }
}
